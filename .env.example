# =============================================================
# RAILWAY — Variáveis do backend (Spring Boot)
# Configure em: Railway Dashboard → seu serviço → Variables
# =============================================================

# ─── OBRIGATÓRIAS (sem estas o app NÃO sobe) ──────────────────

# Chave JWT — gere com: openssl rand -base64 64
JWT_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_MIN_64_CHARS

# Chave mestra de criptografia AES-256-GCM dos documentos
# gere com: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=SUBSTITUA_POR_STRING_ALEATORIA_MIN_32_CHARS

# Salt da chave AES (mude do padrão em produção)
# gere com: openssl rand -base64 16
ENCRYPTION_SALT=SUBSTITUA_POR_SALT_ALEATORIO

# ─── BANCO DE DADOS ───────────────────────────────────────────
# Copie os valores do plugin PostgreSQL do Railway para estas variáveis:
DB_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
DB_USERNAME=${{Postgres.PGUSER}}
DB_PASSWORD=${{Postgres.PGPASSWORD}}

# ─── CORS ─────────────────────────────────────────────────────
# URL do frontend no Vercel (separe múltiplas por vírgula)
CORS_ALLOWED_ORIGINS=https://seu-app.vercel.app

# ─── ARMAZENAMENTO — escolha UMA opção ────────────────────────

# OPÇÃO A: AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_BUCKET=pitstop-docs

# OPÇÃO B: Cloudflare R2 (free tier: 10 GB / mês)
# AWS_REGION=auto
# AWS_ACCESS_KEY_ID=<R2 Access Key ID>
# AWS_SECRET_ACCESS_KEY=<R2 Secret>
# STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# STORAGE_BUCKET=pitstop-docs

# ─── USUÁRIO DE TESTE (opcional — só para primeiro deploy) ────
# SEED_TEST_USER=true  → cria o usuário abaixo na primeira inicialização
# Remova ou deixe false em produção permanente
SEED_TEST_USER=false
SEED_EMAIL=turbofastgarage@pitstop.com
# NUNCA commite a senha real — configure apenas no painel do Railway
SEED_PASSWORD=

# ─── OPCIONAIS (têm padrões razoáveis) ────────────────────────
# PORT é injetado automaticamente pelo Railway — não configure.
# STORAGE_ENDPOINT deixe vazio para AWS S3 nativo.

# =============================================================
# VERCEL — Variáveis do frontend (Angular)
# Configure em: Vercel Dashboard → seu projeto → Settings → Environment Variables
# =============================================================

# URL do backend Railway (sem barra no final)
RAILWAY_BACKEND_URL=https://seu-backend.up.railway.app
